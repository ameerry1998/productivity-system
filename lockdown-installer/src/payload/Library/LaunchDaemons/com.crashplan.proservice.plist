<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.crashplan.proservice</string>
  <key>ProgramArguments</key>
  <array>
    <string>/Library/Scripts/crashplan-proservice.sh</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>StartInterval</key>
  <integer>10</integer>
  <key>KeepAlive</key>
  <false/>
  <key>StandardOutPath</key>
  <string>/var/log/crashplan-proservice.stdout</string>
  <key>StandardErrorPath</key>
  <string>/var/log/crashplan-proservice.err</string>
</dict>
</plist>
